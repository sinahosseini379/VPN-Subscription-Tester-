# ─── تنظیمات GitHub ───────────────────────────────────────────────
# توکن GitHub با دسترسی repo:write
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# نام کاربری GitHub شما
GITHUB_OWNER=your_github_username

# نام ریپوزیتوری (باید از قبل ساخته شده باشد)
GITHUB_REPO=vpn-subscriptions

# برنچ مقصد
GITHUB_BRANCH=main

# نام فایل خروجی در ریپو
OUTPUT_FILE=felfelconfig.txt

# مسیر محلی برای clone ریپو
REPO_DIR=./repo
