# ─── تنظیمات GitHub ───────────────────────────────────────────────
# توکن GitHub با دسترسی repo:write
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# نام کاربری GitHub شما
GITHUB_OWNER=sinahosseini379

# نام ریپوزیتوری (باید از قبل ساخته شده باشد)
GITHUB_REPO=VPN-Subscription-Tester-

# برنچ مقصد
GITHUB_BRANCH=main

# نام فایل خروجی در ریپو
OUTPUT_FILE=best_configs.txt

# مسیر اختیاری باینری xray (اگر نصب محلی یا مسیر سفارشی دارید)
# XRAY_BIN=/path/to/xray

# مسیر محلی برای clone ریپو
REPO_DIR=./repo
